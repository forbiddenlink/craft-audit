{
  "name": "craft-audit",
  "version": "1.0.0",
  "description": "Comprehensive audit tool for Craft CMS projects — template analysis, security scanning, HTTP headers, CVE detection, system checks, and visual regression",
  "main": "dist/cli.js",
  "bin": {
    "craft-audit": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "data/",
    "php/analyze-templates.php",
    "craft-audit.config.schema.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test tests/*.test.cjs",
    "test:watch": "npm run build && node --test --watch tests/*.test.cjs",
    "prepublishOnly": "npm run build && npm test",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "craft-cms",
    "audit",
    "security",
    "twig",
    "performance",
    "visual-regression",
    "n+1",
    "eager-loading",
    "sarif",
    "cve",
    "http-headers",
    "cli"
  ],
  "author": "forbiddenlink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forbiddenlink/craft-audit.git"
  },
  "bugs": {
    "url": "https://github.com/forbiddenlink/craft-audit/issues"
  },
  "homepage": "https://github.com/forbiddenlink/craft-audit#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "minimatch": "^10.2.1",
    "next-safe-action": "^8.3.0",
    "ora": "^5.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "optionalDependencies": {
    "backstopjs": "^6.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "@types/sarif": "^2.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "minimatch": "$minimatch"
  },
  "comment:overrides": "Pin transitive minimatch to our direct v10.x to avoid CVE-2024-XXXXX in minimatch <9.0.5 pulled by backstopjs",
  "private": false
}