{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Craft Audit JSON Output",
  "description": "Schema for the craft-audit JSON reporter output envelope (--output json)",
  "type": "object",
  "required": ["schemaVersion", "toolVersion", "generatedAt", "result"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of this output schema (independent of tool version)",
      "examples": ["1.0.0"]
    },
    "toolVersion": {
      "type": "string",
      "description": "Version of craft-audit that generated this output",
      "examples": ["1.0.0"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the report was generated"
    },
    "result": {
      "$ref": "#/definitions/AuditResult"
    }
  },
  "definitions": {
    "AuditResult": {
      "type": "object",
      "required": ["projectPath", "timestamp", "issues", "summary"],
      "properties": {
        "projectPath": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "craft": { "$ref": "#/definitions/CraftInfo" },
        "plugins": {
          "type": "array",
          "items": { "$ref": "#/definitions/PluginInfo" }
        },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/definitions/AuditIssue" }
        },
        "summary": { "$ref": "#/definitions/Summary" }
      }
    },
    "Summary": {
      "type": "object",
      "required": ["high", "medium", "low", "info", "total"],
      "properties": {
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "AuditIssue": {
      "type": "object",
      "required": ["severity", "category", "message"],
      "properties": {
        "severity": { "type": "string", "enum": ["high", "medium", "low", "info"] },
        "category": { "type": "string", "enum": ["template", "system", "security", "visual"] },
        "ruleId": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "message": { "type": "string" },
        "suggestion": { "type": "string" },
        "code": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "docsUrl": { "type": "string", "format": "uri" },
        "evidence": {
          "type": "object",
          "properties": {
            "snippet": { "type": "string" },
            "details": { "type": "string" },
            "url": { "type": "string" },
            "command": { "type": "string" }
          }
        },
        "fingerprint": { "type": "string" },
        "fix": {
          "type": "object",
          "required": ["safe", "search", "replacement", "description"],
          "properties": {
            "safe": { "type": "boolean" },
            "search": { "type": "string" },
            "replacement": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "CraftInfo": {
      "type": "object",
      "required": ["version", "edition", "phpVersion", "dbDriver"],
      "properties": {
        "version": { "type": "string" },
        "edition": { "type": "string" },
        "updateAvailable": { "type": "string" },
        "phpVersion": { "type": "string" },
        "dbDriver": { "type": "string" }
      }
    },
    "PluginInfo": {
      "type": "object",
      "required": ["name", "handle", "version", "installed", "enabled"],
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "version": { "type": "string" },
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "updateAvailable": { "type": "string" },
        "craft5Compatible": { "type": "boolean" }
      }
    }
  }
}
